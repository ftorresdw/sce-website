# BambooHR careers embed (your subdomain, e.g. servicecompleteelectric.bamboohr.com)
VITE_BAMBOOHR_DOMAIN=

# Sanity CMS (optional — site uses static content when unset)
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Sanity Studio + seed script (Editor token from sanity.io/manage)
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
# SANITY_AUTH_TOKEN=

# reCAPTCHA (add when ready)
# VITE_RECAPTCHA_SITE_KEY=
